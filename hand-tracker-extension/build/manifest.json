{
  "manifest_version": 3,
  "name": "hand landmark",
  "version": "0.1.0",
  "description": "A Chrome extension that detects hand landmarks using MediaPipe.",
  "permissions": ["tabs","sidePanel", "camera" ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "background": {
    "service_worker": "src/background/background.js"
  },
  "action": {
    "default_title": "Hand Landmark"
  },
  "side_panel": {
    "default_path": "index.html"
  }

}
